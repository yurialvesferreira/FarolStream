# FarolStream — copie para .env (o quick_start.sh faz isso e gera o segredo)

# Segredo de assinatura dos tokens SSE. NUNCA use o default em produção.
JWT_SECRET=troque-por-um-segredo-forte

# Infraestrutura
REDIS_URL=redis://redis:6379/0
EVENTS_CHANNEL=farol:events

# SSE
HEARTBEAT_INTERVAL_SECONDS=20
STREAM_QUEUE_MAXSIZE=100
SSE_RETRY_MS=3000

# Auth (handshake)
SSE_TOKEN_TTL_SECONDS=60

# CORS — em produção, restrinja ao domínio do dashboard (separado por vírgula)
CORS_ORIGINS=http://localhost:8080

# Publisher (sobrescrito por serviço no docker-compose)
PUBLISHER_MIN_INTERVAL_SECONDS=0.4
PUBLISHER_MAX_INTERVAL_SECONDS=2.0
